{
  "title": "我的模型监控",
  "apis": [
    {
      "name": "站点A",
      "base_url": "https://your-newapi-a.example.com",
      "api_key": "sk-xxx"
    },
    {
      "name": "站点B",
      "base_url": "https://your-newapi-b.example.com",
      "api_key": "sk-yyy",
      "exclude_patterns": ["*embedding*"]
    }
  ],
  "telegram": {
    "enabled": false,
    "bot_token": "123456:ABC-your-bot-token",
    "chat_id": "your-telegram-user-id",
    "notify_recovery": true,
    "notify_after_failures": 1
  },
  "interval_minutes": 10,
  "timeout_ms": 30000,
  "concurrency": 3,
  "max_tokens": 1,
  "fallback_max_tokens": 4096,
  "exclude_patterns": ["*dall-e*", "*tts*", "*whisper*", "*midjourney*", "*mj_*", "*flux*", "*embedding*", "*embed*", "*rerank*", "*stable-diffusion*", "*sd3*", "*suno*", "*sora*", "*moderation*"],
  "port": 8788,
  "host": "127.0.0.1"
}
